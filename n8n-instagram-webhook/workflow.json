            {
              "id": "is-echo",
              "leftValue": "={{ $json.is_echo }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "no-text",
              "leftValue": "={{ $json.text }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "empty" }
            }
