    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst entry = (body.entry && body.entry[0]) || {};\nconst messaging = (entry.messaging && entry.messaging[0]) || {};\n\nreturn [{\n  json: {\n    sender_id: messaging.sender && messaging.sender.id,\n    recipient_id: messaging.recipient && messaging.recipient.id,\n    message_id: messaging.message && messaging.message.mid,\n    text: messaging.message && messaging.message.text,\n    is_echo: !!(messaging.message && messaging.message.is_echo),\n    timestamp: messaging.timestamp\n  }\n}];"
      },
      "id": "code-parse-payload",
      "name": "Code - Parse Meta Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-140, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "combinator": "or",
