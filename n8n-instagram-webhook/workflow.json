    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO messages (sender_id, direction, text, intent, confidence, created_at)\nVALUES ($1, 'in', $2, NULL, NULL, now())",
        "options": {
          "queryReplacement": "={{ [$json.sender_id, $json.text] }}"
        }
      },
      "id": "pg-log-inbound-paused",
      "name": "Postgres - Log Inbound (Paused)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1060, 320],
      "credentials": { "postgres": { "id": "", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT direction, text, created_at FROM messages\nWHERE sender_id = $1\nORDER BY created_at DESC\nLIMIT 6",
        "options": {
          "queryReplacement": "={{ [$json.sender_id] }}"
        }
      },
      "id": "pg-get-history",
      "name": "Postgres - Get Recent History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1060, 480],
      "credentials": { "postgres": { "id": "", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "jsCode": "// TODO: replace SYSTEM_KB with your real knowledge base + hard rules.\nconst SYSTEM_KB = `You are a helpful Instagram DM assistant for [BUSINESS NAME], replying in Uzbek.\nRules:\n- Only answer using the facts below. Never invent prices, delivery times, or warranty terms.\n- If the customer asks to speak to a human, or you are not confident, set intent to \"handoff\".\n- Keep replies short (1-3 sentences), friendly, and in Uzbek.\n\nFacts:\n- Price: [FILL IN]\n- Installation: [FILL IN]\n- Delivery: [FILL IN]\n- Warranty: [FILL IN]\n- Power/specs: [FILL IN]\n`;\n\nconst state = $('Code - Merge Conversation State').first().json;\nconst historyItems = $input.all().map(i => i.json).reverse();\n\nconst historyText = historyItems\n  .map(m => `${m.direction === 'in' ? 'Customer' : 'Bot'}: ${m.text}`)\n  .join('\\n');\n\nconst messages = [\n  {\n    role: 'user',\n    content: historyText\n      ? `Conversation so far:\\n${historyText}\\n\\nNew customer message: ${state.text}`\n      : `New customer message: ${state.text}`\n  }\n];\n\nreturn [{\n  json: {\n    ...state,\n    system_prompt: SYSTEM_KB,\n    messages\n  }\n}];"
      },
      "id": "code-build-prompt",
      "name": "Code - Build LLM Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 512, system: $json.system_prompt, messages: $json.messages, tools: [ { name: 'classify_and_reply', description: \"Classify the customer's intent and draft a short reply in Uzbek.\", input_schema: { type: 'object', properties: { intent: { type: 'string', enum: ['price','installation','delivery','warranty','power','faq','wants_manager','handoff'] }, reply: { type: 'string' }, confidence: { type: 'number' } }, required: ['intent','reply','confidence'] } } ], tool_choice: { type: 'tool', name: 'classify_and_reply' } }) }}",
        "options": {}
      },
      "id": "http-claude-classify",
      "name": "HTTP Request - Claude Classify + Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 480]
    },
    {
      "parameters": {
        "jsCode": "const state = $('Code - Build LLM Prompt').first().json;\nlet intent = 'handoff';\nlet reply = '';\nlet confidence = 0;\n\ntry {\n  const content = $input.first().json.content || [];\n  const toolUse = content.find(c => c.type === 'tool_use');\n  const parsed = toolUse ? toolUse.input : JSON.parse(content[0].text);\n  intent = parsed.intent || 'handoff';\n  reply = parsed.reply || '';\n  confidence = typeof parsed.confidence === 'number' ? parsed.confidence : 0;\n} catch (e) {\n  intent = 'handoff';\n  reply = '';\n  confidence = 0;\n}\n\nreturn [{ json: { ...state, intent, llm_reply: reply, confidence } }];"
      },
      "id": "code-parse-claude-json",
      "name": "Code - Parse Claude JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 480]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "or", "conditions": [
              { "id": "r-price", "leftValue": "={{ $json.intent }}", "rightValue": "price", "operator": { "type": "string", "operation": "equals" } }
            ] }, "renameOutput": true, "outputKey": "static_template" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "or", "conditions": [
              { "id": "r-installation", "leftValue": "={{ $json.intent }}", "rightValue": "installation", "operator": { "type": "string", "operation": "equals" } }
            ] }, "renameOutput": true, "outputKey": "static_template" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "or", "conditions": [
              { "id": "r-delivery", "leftValue": "={{ $json.intent }}", "rightValue": "delivery", "operator": { "type": "string", "operation": "equals" } }
            ] }, "renameOutput": true, "outputKey": "static_template" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "or", "conditions": [
              { "id": "r-warranty", "leftValue": "={{ $json.intent }}", "rightValue": "warranty", "operator": { "type": "string", "operation": "equals" } }
            ] }, "renameOutput": true, "outputKey": "static_template" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "or", "conditions": [
              { "id": "r-power", "leftValue": "={{ $json.intent }}", "rightValue": "power", "operator": { "type": "string", "operation": "equals" } }
            ] }, "renameOutput": true, "outputKey": "static_template" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "combinator": "and", "conditions": [
              { "id": "r-faq", "leftValue": "={{ $json.intent }}", "rightValue": "faq", "operator": { "type": "string", "operation": "equals" } },
              { "id": "r-faq-conf", "leftValue": "={{ $json.confidence }}", "rightValue": 0.7, "operator": { "type": "number", "operation": "gte" } }
            ] }, "renameOutput": true, "outputKey": "faq" }
          ]
        },
        "fallbackOutput": "extra",
        "options": {}
      },
      "id": "switch-route-intent",
      "name": "Switch - Route Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [2020, 480]
    },
    {
      "parameters": {
        "jsCode": "// TODO: replace with your approved Uzbek wording per intent.\nconst TEMPLATES = {\n  price: \"Narxlar haqida to'liq va aniq ma'lumot beramiz, biroz kuting.\",\n  installation: \"O'rnatish xizmati haqida ma'lumot beramiz, biroz kuting.\",\n  delivery: \"Yetkazib berish shartlari haqida ma'lumot beramiz, biroz kuting.\",\n  warranty: \"Kafolat shartlari haqida ma'lumot beramiz, biroz kuting.\",\n  power: \"Quvvat/texnik xususiyatlar haqida ma'lumot beramiz, biroz kuting.\"\n};\n\nconst state = $input.first().json;\nconst reply = TEMPLATES[state.intent] || \"Ma'lumot uchun tez orada javob beramiz.\";\n\nreturn [{ json: { ...state, reply } }];"
      },
