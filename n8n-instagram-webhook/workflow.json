      "id": "pg-get-conversation",
      "name": "Postgres - Get Conversation State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [340, 400],
      "credentials": { "postgres": { "id": "", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Code - Parse Meta Payload').first().json;\nconst convo = $input.first().json || {};\nreturn [{ json: { ...parsed, bot_paused_until: convo.bot_paused_until || null } }];"
      },
      "id": "code-merge-conversation",
      "name": "Code - Merge Conversation State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [580, 400]
    },
